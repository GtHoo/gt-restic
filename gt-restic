#!/bin/bash

CONFIG_DIR="$HOME/.config/gt-restic"
CONFIG_FILE="$CONFIG_DIR/config"
PASSWORD_FILE="$CONFIG_DIR/password"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: config not found at $CONFIG_FILE"
    exit 1
fi

source "$CONFIG_FILE"
export RESTIC_REPOSITORY
export RESTIC_PASSWORD_FILE="$PASSWORD_FILE"

usage() {
    echo "Usage:"
    echo "  gt-restic --send <file> --type <type> [--type ...]   Backup a file"
    echo "  gt-restic --search <name>                          Search files in backup"
    echo "  gt-restic --restore <name> [--target <dir>]        Restore a file (default: ./restored)"
    echo "  gt-restic --list [--type <type> ...]               List snapshots, optionally by type"
    echo "  gt-restic --forget [<id> ...]                      Remove duplicate snapshots (keeps latest per path),"
    echo "                                                     or remove specific snapshots by ID"
    echo "  gt-restic --init                                   Initialize repository"
    echo ""
    echo "Types: movie, audiobook, game, show, music, other"
}

cmd="$1"
shift

case "$cmd" in
    --send)
        FILE=""
        TAGS=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --type) TAGS+=("$2"); shift 2 ;;
                *)      FILE="$1"; shift ;;
            esac
        done
        if [[ -z "$FILE" || ${#TAGS[@]} -eq 0 ]]; then
            echo "Usage: gt-restic --send <file> --type <type> [--type ...]"
            exit 1
        fi
        if [[ ! -e "$FILE" ]]; then
            echo "Error: '$FILE' not found"
            exit 1
        fi
        TAG_ARGS=()
        for t in "${TAGS[@]}"; do TAG_ARGS+=(--tag "$t"); done
        echo "Backing up '$FILE' with types '${TAGS[*]}'..."
        restic backup "${TAG_ARGS[@]}" -- "$FILE"
        ;;

    --search)
        NAME="$1"
        if [[ -z "$NAME" ]]; then
            echo "Usage: gt-restic --search <name>"
            exit 1
        fi
        echo "Searching for '*${NAME}*' in all snapshots..."
        restic find "*${NAME}*"
        ;;

    --restore)
        NAME=""
        TARGET="./restored"
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --target) TARGET="$2"; shift 2 ;;
                *)        NAME="$1"; shift ;;
            esac
        done
        if [[ -z "$NAME" ]]; then
            echo "Usage: gt-restic --restore <name> [--target <dir>]"
            exit 1
        fi
        echo "Restoring '*${NAME}*' to '$TARGET'..."
        restic restore latest --include "*${NAME}*" --target "$TARGET"
        ;;

    --list)
        TAGS=()
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --type) TAGS+=("$2"); shift 2 ;;
                *)      shift ;;
            esac
        done
        if [[ ${#TAGS[@]} -gt 0 ]]; then
            TAG_ARGS=()
            for t in "${TAGS[@]}"; do TAG_ARGS+=(--tag "$t"); done
            echo "Snapshots with types '${TAGS[*]}':"
            restic snapshots "${TAG_ARGS[@]}"
        else
            echo "All snapshots:"
            restic snapshots
        fi
        ;;

    --forget)
        if [[ $# -gt 0 ]]; then
            echo "Forgetting snapshots: $*..."
            restic forget "$@"
        else
            echo "Forgetting older duplicate snapshots (keeping latest per path)..."
            restic forget --group-by paths --keep-last 1
        fi
        ;;

    --init)
        echo "Initializing repository at $RESTIC_REPOSITORY..."
        restic init
        ;;

    --help|-h|"")
        usage
        ;;

    *)
        echo "Unknown command: $cmd"
        usage
        exit 1
        ;;
esac
