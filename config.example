# gt-restic configuration example
# Copy this to 'config' and fill in your values:
#   cp ~/.config/gt-restic/config.example ~/.config/gt-restic/config

# Your rclone remote name for Jottacloud (check with: rclone listremotes)
# followed by the path/folder to store the backup in
RESTIC_REPOSITORY="rclone:jottacloud:media-backups"
